			<inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.001"></inertia>
		</inertial>
		<visual>
			<origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"></origin>
			<geometry>
				<box size="0.1 0.05 0.1"></box>
			</geometry>
			<material name="Cyan9">
				<color rgba="1.0 0.0 0.0 1.0"></color>
