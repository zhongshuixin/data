	</link>

	<!-- joint部分-->
	<joint name="joint1" type="revolute">
		<origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"></origin>
		<parent link="base_link"></parent>
		<child link="link1"></child>
		<axis xyz="0 0 1"></axis>
		<limit effort="100.0" lower="-3.14" upper="3.14" velocity="1"></limit>
	</joint>
	<joint name="joint2" type="revolute">
		<origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"></origin>
		<parent link="link1"></parent>
		<child link="link2"></child>
		<axis xyz="1 0 0"></axis>
		<limit effort="100.0" lower="-3.14" upper="3.14" velocity="1"></limit>
	</joint>
	<joint name="joint3" type="revolute">
		<origin xyz="0.0 0.0 0.3" rpy="0.0 0.0 0.0"></origin>
		<parent link="link2"></parent>
		<child link="link3"></child>
		<axis xyz="1 0 0"></axis>
		<limit effort="100.0" lower="-3.14" upper="3.14" velocity="1"></limit>
	</joint>
	<joint name="joint4" type="revolute">
		<origin xyz="0.0 0.0 0.3" rpy="0.0 0.0 0.0"></origin>
		<parent link="link3"></parent>
		<child link="link4"></child>
		<axis xyz="1 0 0"></axis>
		<limit effort="100.0" lower="-3.14" upper="3.14" velocity="1"></limit>
	</joint>
	<joint name="joint5" type="revolute">
		<origin xyz="0.0 0.0 0.3" rpy="0.0 0.0 0.0"></origin>
		<parent link="link4"></parent>
		<child link="link5"></child>
		<axis xyz="1 0 0"></axis>
		<limit effort="100.0" lower="-3.14" upper="3.14" velocity="1"></limit>
	</joint>
	<joint name="joint6" type="revolute">
		<origin xyz="0.0 0.0 0.3" rpy="0.0 0.0 0.0"></origin>
		<parent link="link5"></parent>
		<child link="gripper_base_link"></child>
		<axis xyz="0 0 1"></axis>
		<limit effort="100.0" lower="-3.14" upper="3.14" velocity="1"></limit>
	</joint>
	<joint name="hand_right_joint" type="prismatic">
		<origin xyz="0.0 -0.075 0.05" rpy="0.0 0.0 0.0"></origin>
		<parent link="gripper_base_link"></parent>
		<child link="hand_right_link"></child>
		<axis xyz="0 1 0"></axis>
		<limit effort="3000.0" lower="0" upper="0.05" velocity="0.03"></limit>
	</joint>
	<joint name="hand_left_joint" type="prismatic">
		<origin xyz="0.0 0.075 0.05" rpy="0.0 0.0 0.0"></origin>
		<parent link="gripper_base_link"></parent>
		<child link="hand_left_link"></child>
		<axis xyz="0 -1 0"></axis>
		<limit effort="3000.0" lower="0" upper="0.05" velocity="0.03"></limit>
		<mimic joint="hand_right_joint"></mimic>
	</joint>
</robot>