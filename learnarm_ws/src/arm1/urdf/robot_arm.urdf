			</material>
		</visual>
		<collision>
			<origin xyz="0.0 0.0 0.15" rpy="0.0 0.0 0.0"></origin>
			<geometry>
				<cylinder radius="0.05" length="0.3"></cylinder>
			</geometry>
		</collision>
	</link>
	<link name="link5">
		<inertial>
			<origin xyz="0.0 0.0 0.15" rpy="0.0 0.0 0.0"></origin>
			<mass value="1"></mass>
			<inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.001"></inertia>
		</inertial>
		<visual>
			<origin xyz="0.0 0.0 0.15" rpy="0.0 0.0 0.0"></origin>
			<geometry>
				<cylinder radius="0.05" length="0.3"></cylinder>
			</geometry>
			<material name="Cyan6">
				<color rgba="0.0 1.0 0.0 1.0"></color>
			</material>
