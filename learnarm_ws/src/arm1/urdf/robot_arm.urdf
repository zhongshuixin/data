	<link name="gripper_base_link">
		<inertial>
			<origin xyz="0.0 0.0 0.025" rpy="0.0 0.0 0.0"></origin>
			<mass value="1"></mass>
			<inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.001"></inertia>
		</inertial>
		<visual>
			<origin xyz="0.0 0.0 0.025" rpy="0.0 0.0 0.0"></origin>
			<geometry>
