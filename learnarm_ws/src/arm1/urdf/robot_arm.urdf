<?xml version="1.0" encoding="utf-8"?>
<robot name="arm">
	<link name="base_link">
		<inertial>
			<origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"></origin>
			<mass value="1"></mass>
			<inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.001"></inertia>
		</inertial>
		<visual>
			<origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"></origin>
			<geometry>
				<box size="0.3 0.3 0.1"></box>
			</geometry>
			<material name="Cyan1">
				<color rgba="0 0.5 0.5 1"></color>
			</material>
		</visual>
		<collision>
			<origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"></origin>
			<geometry>
				<box size="0.3 0.3 0.1"></box>
			</geometry>
		</collision>
	</link>
	<link name="link1">
		<inertial>
			<origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"></origin>
			<mass value="1"></mass>
			<inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.001"></inertia>
		</inertial>
		<visual>
			<origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"></origin>
			<geometry>
				<cylinder radius="0.05" length="0.1"></cylinder>
			</geometry>
			<material name="Cyan2">
				<color rgba="1.0 1.0 0.0 1.0"></color>
			</material>
		</visual>
		<collision>
			<origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"></origin>
			<geometry>
				<cylinder radius="0.05" length="0.1"></cylinder>
			</geometry>
		</collision>
	</link>
	<link name="link2">
		<inertial>
			<origin xyz="0.0 0.0 0.15" rpy="0.0 0.0 0.0"></origin>
			<mass value="1"></mass>
			<inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.001"></inertia>
