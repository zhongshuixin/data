<?xml version="1.0"?>
<robot name="red_box">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.0025" rpy="0 0 0" />
      <mass value="100" />
      <inertia ixx="100" ixy="0" ixz="0" iyy="100" iyz="0" izz="100" />
    </inertial>

    <visual>
      <geometry>
        <box size="0.2 0.2 0.005" />
      </geometry>
      <origin xyz="0 0 0.0025" rpy="0 0 0" />
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0" />  <!-- 红色 -->
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.0025" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.2 0.005" />
      </geometry>
    </collision>
  </link>
  <link name="around_link1">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="100" />
      <inertia ixx="100" ixy="0" ixz="0" iyy="100" iyz="0" izz="100" />
    </inertial>

    <visual>
      <geometry>
        <box size="0.2 0.005 0.1" />
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0" />  <!-- 红色 -->
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.005 0.1" />
      </geometry>
    </collision>
  </link>
  <link name="around_link2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="100" />
      <inertia ixx="100" ixy="0" ixz="0" iyy="100" iyz="0" izz="100" />
    </inertial>

    <visual>
      <geometry>
        <box size="0.2 0.005 0.1" />
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0" />  <!-- 红色 -->
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.2 0.005 0.1" />
      </geometry>
    </collision>
  </link>
  <link name="around_link3">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="100" />
      <inertia ixx="100" ixy="0" ixz="0" iyy="100" iyz="0" izz="100" />
    </inertial>

    <visual>
      <geometry>
        <box size="0.005 0.205 0.1" />
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0" />  <!-- 红色 -->
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.005 0.205 0.1" />
      </geometry>
    </collision>
  </link>
  <link name="around_link4">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="100" />
      <inertia ixx="100" ixy="0" ixz="0" iyy="100" iyz="0" izz="100" />
    </inertial>

    <visual>
      <geometry>
        <box size="0.005 0.205 0.1" />
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0" />  <!-- 红色 -->
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.005 0.205 0.1" />
      </geometry>
    </collision>
  </link>

  <joint name="joint1" type="fixed">
    <parent link="base_link" />
    <child link="around_link1" />
    <origin xyz="0 -0.1 0.05" rpy="0 0 0" />
  </joint>
  <joint name="joint2" type="fixed">
    <parent link="base_link" />
    <child link="around_link2" />
    <origin xyz="0 0.1 0.05" rpy="0 0 0" />
  </joint>
  <joint name="joint3" type="fixed">
    <parent link="base_link" />
    <child link="around_link3" />
    <origin xyz="-0.1 0 0.05" rpy="0 0 0" />
  </joint>
  <joint name="joint4" type="fixed">
    <parent link="base_link" />
    <child link="around_link4" />
    <origin xyz="0.1 0 0.05" rpy="0 0 0" />
  </joint>
</robot>